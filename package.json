{
  "name": "@aabadin/opencode-model-forecast",
  "version": "0.4.0",
  "description": "Model + effort forecast plugin for OpenCode with supervised multi-provider fallback recovery.",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    }
  },
  "bin": {
    "model-forecast": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "model-forecast",
    "model-selection",
    "rate-limit",
    "fallback",
    "ai",
    "llm",
    "sdd"
  ],
  "author": "aabadin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianabadin/subagentsplugin.git"
  },
  "bugs": {
    "url": "https://github.com/adrianabadin/subagentsplugin/issues"
  },
  "homepage": "https://github.com/adrianabadin/subagentsplugin#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "25.7.0",
    "@vitest/coverage-v8": "4.1.6",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.17.11"
  },
  "engines": {
    "node": ">=24 <25",
    "opencode": ">=1.17.11"
  },
  "dependencies": {
    "solid-js": "^1.9.12"
  }
}
